[Desktop Entry]
Type=Service
MimeType=image/png;image/jpeg;image/webp;image/tiff;image/bmp;
Actions=imgToPdf
X-KDE-Submenu=PDF Actions
X-KDE-Submenu[es]=Acciones PDF

[Desktop Action imgToPdf]
Name=Combine into a PDF
Name[es]=Unir en un PDF
Icon=application-pdf
Exec=/usr/share/conversor-dolphin/img-a-pdf.sh %F
