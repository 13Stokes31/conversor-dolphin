[Desktop Entry]
Type=Service
MimeType=application/epub+zip;application/x-mobipocket-ebook;application/vnd.amazon.ebook;application/x-mobi8-ebook;application/x-fictionbook+xml;
Actions=ebookToPdf
X-KDE-Submenu=Convert e-book
X-KDE-Submenu[es]=Convertir libro

[Desktop Action ebookToPdf]
Name=to PDF
Name[es]=a PDF
Icon=application-pdf
Exec=/usr/share/conversor-dolphin/ebook-a-pdf.sh %F
