pkgbase = conversor-dolphin
	pkgdesc = Dolphin (KF6) service menu to manage PDF and convert PDF, images, SVG, audio, video, e-books and office files
	pkgver = 1.3.0
	pkgrel = 1
	url = https://github.com/Stokes/conversor-dolphin
	install = conversor-dolphin.install
	arch = any
	license = MIT
	depends = poppler
	depends = kdialog
	optdepends = ghostscript: comprimir PDF
	optdepends = img2pdf: convertir imágenes a PDF (sin pérdida)
	optdepends = imagemagick: convertir entre formatos de imagen (JPG/PNG/WebP/AVIF/TIFF, HEIC…)
	optdepends = ffmpeg: convertir audio y vídeo
	optdepends = librsvg: convertir SVG a PNG/PDF
	optdepends = calibre: convertir libros electrónicos (EPUB/MOBI/AZW…) a PDF
	optdepends = libreoffice-still: convertir documentos de oficina a PDF (o libreoffice-fresh)
	optdepends = ocrmypdf: OCR, añadir capa de texto buscable a un PDF
	optdepends = tesseract-data-spa: datos de OCR en español
	source = pdf-unir.sh
	source = pdf-dividir.sh
	source = pdf-convertir.sh
	source = img-a-pdf.sh
	source = office-a-pdf.sh
	source = img-convertir.sh
	source = audio-convertir.sh
	source = video-convertir.sh
	source = svg-convertir.sh
	source = ebook-a-pdf.sh
	source = conversor-dolphin-pdf.desktop
	source = conversor-dolphin-unir.desktop
	source = conversor-dolphin-imagenes.desktop
	source = conversor-dolphin-oficina.desktop
	source = conversor-dolphin-audio.desktop
