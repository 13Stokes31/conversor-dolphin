[Desktop Entry]
Type=Service
MimeType=audio/mpeg;audio/flac;audio/x-flac;audio/wav;audio/x-wav;audio/ogg;audio/x-vorbis+ogg;audio/opus;audio/x-opus+ogg;audio/mp4;audio/x-m4a;audio/aac;
Actions=audMp3;audFlac;audWav;audOgg;audOpus;audM4a
X-KDE-Submenu=Convert audio
X-KDE-Submenu[es]=Convertir audio

[Desktop Action audMp3]
Name=to MP3
Name[es]=a MP3
Icon=audio-x-generic
Exec=/usr/share/conversor-dolphin/audio-convertir.sh mp3 %F

[Desktop Action audFlac]
Name=to FLAC
Name[es]=a FLAC
Icon=audio-x-generic
Exec=/usr/share/conversor-dolphin/audio-convertir.sh flac %F

[Desktop Action audWav]
Name=to WAV
Name[es]=a WAV
Icon=audio-x-generic
Exec=/usr/share/conversor-dolphin/audio-convertir.sh wav %F

[Desktop Action audOgg]
Name=to OGG (Vorbis)
Name[es]=a OGG (Vorbis)
Icon=audio-x-generic
Exec=/usr/share/conversor-dolphin/audio-convertir.sh ogg %F

[Desktop Action audOpus]
Name=to Opus
Name[es]=a Opus
Icon=audio-x-generic
Exec=/usr/share/conversor-dolphin/audio-convertir.sh opus %F

[Desktop Action audM4a]
Name=to M4A (AAC)
Name[es]=a M4A (AAC)
Icon=audio-x-generic
Exec=/usr/share/conversor-dolphin/audio-convertir.sh m4a %F
